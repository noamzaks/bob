# This file was automatically generated by Bob.
builddir = build/.bob

rule bob-1
  command = echo $something > $out

rule bob-2
  command = echo $something $something > $out

build build/hi: bob-1
  something = hi
build build/bye: bob-1
  something = bye
build build/hi-again: bob-1
  something = hi
build build/bye-again: bob-1
  something = bye
build build/bye-another: bob-2
  something = bye
build build/escape: bob-1
  something = $$money
rule configure-bob-3
  command = FORCE_COLOR=1 $bobbin configure -f $bobfile
  description = CONFIGURE $out
  generator = 1
  pool = console

build build/.bob/build.ninja: configure-bob-3 | $
    $root/tests/cases/variables.bob
  bobbin = $root/.venv/bin/python -m bob
  bobfile = $root/tests/cases/variables.bob
