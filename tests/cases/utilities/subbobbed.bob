from bob.prelude import *

r = use("r")

export(
    built=r.build(
        "dummy", inputs=["subbob-input", config("subbob-config", required=True)]
    )
)

src_in("dangeling")
src_in("inside")
with src_in("not-dangeling"):
    pass
build_in("dangeling")

with plugin_scope():
    r = Rule("echo $variable > $out")
    r["variable"].set(["fun"])
    r["variable"].add(["more"])
    export(r=r)
